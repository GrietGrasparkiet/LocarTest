{
  "name": "locar",
  "version": "0.2.3",
  "description": "Location-based AR from AR.js.",
  "files": [
    "dist"
  ],
  "main": "./dist/locar.umd.js",
  "module": "./dist/locar.es.js",
  "types": "./dist/locar.d.ts",
  "exports": {
    ".": {
      "types": "./dist/locar.d.ts",
      "import": "./dist/locar.es.js",
      "require": "./dist/locar.umd.js"
    }
  },
  "scripts": {
    "lint": "eslint ./lib --ext .js,.json,.css",
    "lint:fix": "prettier --write ./lib && eslint ./lib --ext .js,.json,.css --fix",
    "typecheck": "tsc --noEmit",
    "build": "npm run lint && npm run typecheck && vite build && npm pack",
    "makedocs": "typedoc --out docs/api lib/three/main.ts"
  },
  "devDependencies": {
    "@eslint/css": "^0.11.0",
    "@eslint/js": "^9.35.0",
    "@eslint/json": "^0.13.2",
    "@types/three": "^0.181.0",
    "esbuild":"^0.28.1",
    "eslint": "^9.38.0",
    "globals": "^16.4.0",
    "typedoc": "^0.28.19",
    "minimatch": "^9.0.7",
    "prettier-eslint": "^16.4.2",
    "typescript": "^5.9.3",
    "vite": "^8.0.16",
    "vite-plugin-dts": "^4.5.4"
  },
  "dependencies": {
    "minimatch": "^9.0.7",
    "three": "^0.180.0"
  },
  "overrides" : {
    "prettier-eslint": {
      "minimatch": "$minimatch"
    },
    "vite": {
      "esbuild": "$esbuild"
    }
  }
}
